.DS_Store
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/

# Local large datasets and model artifacts.
projects/*/data/raw/*
!projects/*/data/raw/.gitkeep
projects/*/data/sampled/*
!projects/*/data/sampled/.gitkeep
projects/*/data/processed/*
!projects/*/data/processed/.gitkeep
projects/*/data/local/*
projects/*/models/

# Run model artifacts (model.pkl, scores feather, etc.) are committed for
# in-run reproducibility + traceability. Only intermediate caches and editor
# locks are ignored; raw input data stays excluded (see data/ rules above).
projects/*/runs/**/cache/
projects/*/runs/**/.~*.xlsx

# Local generated package metadata.
*.egg-info/

# Local agent/editor configuration.
.codex/
.claude/settings.json

# Vendor D03 refinement intermediate results
projects/*/runs/feature_refine_feather_vendor_d03/

# Keep curated metadata under data/profile tracked.

# Local skill checkout is optional; runtime code is vendored under vendor/.
my-skills/

# Jupyter auto-generated checkpoints.
.ipynb_checkpoints/
